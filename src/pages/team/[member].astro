---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Newsletter from "../../components/Newsletter.astro";
import Footer from "../../components/Footer.astro";
import instagram from "../../assets/Instagram.png";
import facebook from "../../assets/Facebook.png";
import sarah2 from "../../assets/Sarah2.png";
import { members } from "../../data/members.js";

export function getStaticPaths() {
  return members.map((m) => ({
    params: { member: m.slug },
    props: { member: m },
  }));
}

const { member } = Astro.props;
---

<Layout>
  <Header />

  <section class="profile">
    <div class="profile__inner">

      <!-- Venstre -->
      <div class="profile__left">
        <div class="profile__photowrap">
          <div class="profile__deco" aria-hidden="true"></div>
          <img src={sarah2.src} alt={member.name} class="profile__photo" />
        </div>
        <div class="profile__socials">
          <a href="#" aria-label="Instagram">
            <img src={instagram.src} alt="Instagram" width="24" height="24" />
          </a>
          <a href="#" aria-label="Facebook">
            <img src={facebook.src} alt="Facebook" width="24" height="24" />
          </a>
        </div>
      </div>

      <!-- Højre -->
      <div class="profile__right">
        <div class="profile__intro">
          <h1 class="profile__name">{member.name}</h1>
          <p class="profile__role">{member.role}</p>
          <p class="profile__bio">{member.bio}</p>
        </div>

        <hr class="profile__divider" />

        <div class="profile__experience">
          <h2 class="profile__exp_title">Past experience</h2>
          <p class="profile__exp_body">{member.experience}</p>
        </div>
      </div>

    </div>
  </section>

  <Newsletter />
  <Footer />
</Layout>

<style>
  /* Section */
  .profile {
    padding: var(--space-3xl) 0;
    min-height: 60vh;
  }

  .profile__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Venstre */
  .profile__left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-m);
  }

  .profile__photowrap {
    position: relative;
    width: 478px;
    max-width: 100%;
    margin-top: var(--space-xl);
  }

  .profile__deco {
    position: absolute;
    top: -24px;
    left: -24px;
    width: 233px;
    height: 164px;
    background: var(--color-green);
    border-radius: 12px;
    z-index: 0;
  }

  .profile__photo {
    position: relative;
    z-index: 1;
    width: 478px;
    height: 504px;
    max-width: 100%;
    object-fit: cover;
    border-radius: 20px;
    display: block;
  }

  /* Sociale */
  .profile__socials {
    display: flex;
    gap: var(--space-s);
    align-items: center;
  }

  .profile__socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .profile__socials a:hover {
    opacity: 1;
  }

  /* Højre */
  .profile__right {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
    padding-top: var(--space-xl);
  }

  .profile__intro {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .profile__name {
    margin: 0;
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
  }

  .profile__role {
    margin: 0;
    font-family: Lato;
    font-size: 18px;
    font-weight: 400;
    line-height: 160%;
    color: var(--color-text-muted);
  }

  .profile__bio {
    margin: 0;
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 160%;
    color: var(--color-text-muted);
  }

  .profile__divider {
    border: none;
    border-top: 1px solid var(--color-border-light);
    margin: 0;
  }

  /* Erfaring */
  .profile__experience {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .profile__exp_title {
    margin: 0;
    font-family: "Cabin Variable";
    font-size: 30px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
  }

  .profile__exp_body {
    margin: 0;
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 160%;
    color: var(--color-text-muted);
  }

  /* Responsive */
  @media (max-width: 1280px) {
    .profile__inner {
      padding: 0 var(--space-l);
    }
  }

  @media (max-width: 768px) {
    .profile__inner {
      grid-template-columns: 1fr;
    }

    .profile__right {
      padding-top: 0;
    }

    .profile__photowrap {
      max-width: 100%;
    }
  }
</style>
