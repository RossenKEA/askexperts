---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PageHero from "../../components/PageHero.astro";
import instagram from "../../assets/Instagram.png";
import facebook from "../../assets/Facebook.png";
import { members as memberData } from "../../data/members.js";
import sarah from "../../assets/Sarah.jpg";
import john from "../../assets/John.jpg";
import daisy from "../../assets/Daisy.jpg";
import maya from "../../assets/Maya.jpg";
import ryan from "../../assets/Ryan.png";
import lily from "../../assets/Lily.jpg";

const photos = {
  sarah: sarah.src,
  john: john.src,
  daisy: daisy.src,
  maya: maya.src,
  ryan: ryan.src,
  lilly: lily.src,
};

const members = memberData.map((m) => ({ ...m, photo: photos[m.slug as keyof typeof photos] }));
---

<Layout>
  <Header />

  <PageHero
    label="TEAM"
    title="The Consultors"
    subhead="Our success stems from the synergy between dedicated teams and our valued clients. We prioritize a company culture that fosters exceptional productivity, ensures customer satisfaction."
  />

  <section class="team">
    <div class="team__inner">
      <div class="team__intro">
        <div class="team__introtext">
          <h2 class="team__title">Meet Our Great Team</h2>
          <p class="team__body">
            Welcome to our amazing team! We are a group of passionate
            individuals dedicated to excellence and innovation. Each member
            brings unique skills and experiences, working together to achieve
            our goals. Join us as we embark on exciting projects and create
            lasting impacts.
          </p>
        </div>
        <button class="cta_btn">Join our team</button>
      </div>

      <div class="team__grid">
        {members.map((m) => (
          <div class="team__card">
            {m.slug === "sarah" && <a href={`/team/${m.slug}`} class="team__card_link" aria-label={m.name}></a>}
            <div class="team__photowrap">
              <img src={m.photo} alt={m.name} class="team__photo" />
              <span class="team__badge">{m.role}</span>
            </div>
            <div class="team__info">
              <h3 class="team__name">{m.name}</h3>
              <p class="team__bio">{m.shortBio}</p>
              <div class="team__socials">
                <a href="#" aria-label="Instagram" class="team__social_link">
                  <img src={instagram.src} alt="Instagram" width="20" height="20" />
                </a>
                <a href="#" aria-label="Facebook" class="team__social_link">
                  <img src={facebook.src} alt="Facebook" width="20" height="20" />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* Hero */
  /* Team section */
  .team {
    padding: var(--space-3xl) 0;
    background: var(--color-white);
  }

  .team__inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* Intro row */
  .team__intro {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-l);
  }

  .team__introtext {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    max-width: 560px;
  }

  .team__title {
    margin: 0;
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
  }

  .team__body {
    margin: 0;
    font-family: Lato;
    font-size: 18px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-text-muted);
  }

  /* Grid */
  .team__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-m);
  }

  /* Card */
  .team__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    position: relative;
  }

  .team__card_link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .team__social_link {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .team__photowrap {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
  }

  .team__photo {
    width: 100%;
    height: 392px;
    object-fit: cover;
    display: block;
  }

  .team__badge {
    position: absolute;
    bottom: 14px;
    right: 14px;
    background: var(--color-black);
    color: var(--color-white);
    font-family: Lato;
    font-size: 13px;
    font-weight: 400;
    height: 34px;
    padding: 0 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
  }

  .team__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-align: center;
    align-items: center;
  }

  .team__name {
    margin: 0;
    font-family: "Cabin Variable";
    font-size: 24px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
  }

  .team__bio {
    margin: 0;
    font-family: Lato;
    font-size: 15px;
    font-weight: 400;
    line-height: 160%;
    color: var(--color-text-muted);
    max-width: 280px;
  }

  .team__socials {
    display: flex;
    gap: var(--space-xs);
    align-items: center;
  }

  .team__socials img {
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .team__socials a:hover img {
    opacity: 1;
  }

  /* CTA button */
  .cta_btn {
    width: 168px;
    height: 59px;
    border-radius: 42px;
    border: none;
    background: var(--color-black);
    color: var(--color-white);
    font-family: Lato;
    font-size: var(--step-0);
    font-weight: 400;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 1280px) {
    .team__inner {
      padding: 0 var(--space-l);
    }
  }

  @media (max-width: 900px) {
    .team__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--step-4);
    }

    .team__intro {
      flex-direction: column;
      align-items: flex-start;
    }

    .team__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
