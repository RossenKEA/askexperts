---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatToExpect from "../components/WhatToExpect.astro";
import CoreValues from "../components/CoreValues.astro";
import ourvisionImage from "../assets/ourvision.png";
import teamImage1 from "../assets/team1.png";
import teamImage2 from "../assets/team2.png";
import Button from "../components/Button.astro";
import PageHero from "../components/PageHero.astro";
---

<Layout>
  <Header />

  <PageHero
    label="ABOUT"
    title="Igniting Innovation"
    subhead="Our strength lies in the collaboration between our talented teams and esteemed clients. We cultivate a workplace that champions innovation, promotes peak performance, and guarantees client satisfaction."
  />
  <WhatToExpect
    reverse={true}
    imageSrc={ourvisionImage.src}
    imageAlt="Image of employees"
    eyebrow="OUR VISION"
    heading="Turn your ideas into reality."
    body="Capitalize on low hanging fruit to identify a ballpark value added activity beta test. Override the digital divide with additional from DevOps."
    items={[
      "Bring to the table win-win survival strategies to ensure proactive domination. At the end of the day.",
      "Capitalize on low hanging fruit to identify a ballpark value added activity to beta test override the digital.",
    ]}
  />
  <div class="counter">
    <div class="counter__text">
      <h1>1128+</h1>
      <p>Successful Work</p>
    </div>
    <div class="counter__text">
      <h1>908+</h1>
      <p>Team member</p>
    </div>
    <div class="counter__text">
      <h1>258+</h1>
      <p>Happy Customers</p>
    </div>
    <div class="counter__text">
      <h1>564+</h1>
      <p>Creative Idea</p>
    </div>
  </div>
  <CoreValues />
  <section class="team__section">
    <div class="team__content">
      <div class="team__textcontent">
        <div class="team__subtext">
          <p>OUR TEAM</p>
        </div>
        <div class="team__text">
          <h1>We champion the bold</h1>
          <p>
            Our success stems from the synergy between dedicated teams and our
            valued clients. We prioritize a company culture that fosters
            exceptional productivity, ensures customer satisfaction.
          </p>
        </div>
        <a href="/team"><Button id="team-btn" text="Meet the Team" paddingX="16px" /></a>
      </div>
      <div class="team__team">
        <div class="team__responsive">
          <img src={teamImage1.src} alt="woman" />
          <div class="team__responsivetext">
            <div>
              <h2>Sarah Jasmine</h2>
              <h3>CEO at Company</h3>
              <p>
                Driving innovation and leadership with a focus on strategic
                growth and impactful decisions.
              </p>
            </div>
          </div>
        </div>
        <div class="team__responsive">
          <img src={teamImage2.src} alt="man" />
          <div class="team__responsivetext">
            <div>
              <h2>John Carter</h2>
              <h3>Manager</h3>
              <p>
                Expert in operational efficiency, ensuring smooth processes and
                exceptional team performance.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="faq">
    <div class="faq__card">
      <div class="faq__header">
        <p class="faq__eyebrow">FAQ</p>
        <h2 class="faq__title">Customer Questions</h2>
      </div>

      <div class="faq__list">
        <div class="faq__item">
          <div class="faq__question-row">
            <h3 class="faq__question">
              What will happen when I’ve sent my application?
            </h3>
            <button class="faq__toggle" aria-label="Open FAQ item" type="button"
              >+</button
            >
          </div>
        </div>

        <div class="faq__item faq__item--open">
          <div class="faq__question-row">
            <h3 class="faq__question">
              Can I get a free trial before I purchase?
            </h3>
            <button
              class="faq__toggle"
              aria-label="Close FAQ item"
              type="button">−</button
            >
          </div>
          <p class="faq__answer">
            Ippsum is the result of synergy between our teams and our customers.
            Our company culture is focused on excellent productivity, customer
            satisfaction, respect for team and individual achievements.
          </p>
        </div>

        <div class="faq__item">
          <div class="faq__question-row">
            <h3 class="faq__question">
              What should I include in my personal statement?
            </h3>
            <button class="faq__toggle" aria-label="Open FAQ item" type="button"
              >+</button
            >
          </div>
        </div>

        <div class="faq__item">
          <div class="faq__question-row">
            <h3 class="faq__question">
              Will membership plans be charged automatically?
            </h3>
            <button class="faq__toggle" aria-label="Open FAQ item" type="button"
              >+</button
            >
          </div>
        </div>

        <div class="faq__item">
          <div class="faq__question-row">
            <h3 class="faq__question">
              What will happen when I’ve sent my application?
            </h3>
            <button class="faq__toggle" aria-label="Open FAQ item" type="button"
              >+</button
            >
          </div>
        </div>

        <div class="faq__item">
          <div class="faq__question-row">
            <h3 class="faq__question">
              Can I get a free trial before I purchase?
            </h3>
            <button class="faq__toggle" aria-label="Open FAQ item" type="button"
              >+</button
            >
          </div>
        </div>
      </div>
    </div>
  </section>
  <Footer />
</Layout>

<style>
  .faq {
    padding: 80px 20px;

    margin-bottom: 300px;
  }

  .faq__card {
    max-width: 760px;
    margin: 0 auto;
    background: var(--color-surface-secondary, #f9fafb);
    border-radius: 24px;
    padding: 150px 200px 150px;
  }

  .faq__header {
    text-align: center;
    margin-bottom: 36px;
  }

  .faq__eyebrow {
    margin: 0 0 10px;
    font-size: 14px;
    line-height: 1.4;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-text-muted);

    font-family: Lato;
  }

  .faq__title {
    margin: 0;
    font-family: "Cabin Variable", sans-serif;
    font-size: 46px;
    line-height: 1.1;
    font-weight: 700;
  }

  .faq__list {
    display: flex;
    flex-direction: column;
  }

  .faq__item {
    border-bottom: 1px solid #d9d9d9;
    padding: 0;
  }

  .faq__question-row {
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .faq__question {
    margin: 0;
    font-family: Cabin Variable;
    font-size: 17px;
    line-height: 1.45;
    font-weight: 500;
  }

  .faq__toggle {
    flex-shrink: 0;
    border: none;
    background: transparent;
    padding: 0;
    width: 24px;
    height: 24px;
    font-size: 28px;
    line-height: 1;
    font-weight: 300;
    cursor: pointer;
  }

  .faq__answer {
    margin: -4px 0 14px;
    max-width: 520px;
    font-family: Lato;
    font-size: 14px;
    line-height: 1.8;
    color: var(--color-text-muted);
  }

  .team__section {
    display: flex;
    padding: 100px 360px;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .team__content {
    display: inline-grid;
    row-gap: 32px;
    column-gap: 32px;
    grid-template-rows: repeat(1, fit-content(100%));
  }

  .team__textcontent {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
    align-self: stretch;
    grid-row: 1 / span 1;
    grid-column: 1 / span 1;
  }

  .team__subtext {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    border-radius: 20px;
  }
  .team__subtext p {
    font-family: Lato;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 147.5%; /* 23.6px */
    letter-spacing: 2.32px;
    text-transform: uppercase;
    margin: 0;
  }
  .team__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 11px;
    align-self: stretch;
  }
  .team__text h1 {
    font-family: Cabin Variable;
    font-size: 45px;
    font-style: normal;
    font-weight: 700;
    line-height: 116%; /* 52.2px */
    align-self: stretch;
    margin: 0;
  }
  .team__text p {
    margin: 0;
    align-self: stretch;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 147.5%; /* 23.6px */
  }

  .team__team {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 48px;
    grid-row: 1 / span 1;
    grid-column: 2 / span 1;
    justify-self: stretch;
  }
  .team__responsive {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 25px;
    align-self: stretch;
  }
  .team__responsive img {
    width: 210px;
    height: 224.918px;
    aspect-ratio: 183/196;
  }
  .team__responsivetext {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 27px;
    flex: 1 0 0;
  }
  .team__responsivetext div {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 13px;
    align-self: stretch;
  }
  .team__responsivetext h2 {
    text-align: center;
    font-family: Cabin Variable;
    font-size: 30px;
    font-style: normal;
    font-weight: 700;
    line-height: 116%; /* 34.8px */
    margin: 0;
  }
  .team__responsivetext h3 {
    margin: 0;
    font-family: Lato;
    font-size: 18px;
    font-style: normal;
    font-weight: 600;
    line-height: 160%; /* 28.8px */
  }
  .team__responsivetext p {
    margin: 0;
    align-self: stretch;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 18px;
    font-style: normal;
    font-weight: 400;
    line-height: 147.5%; /* 26.55px */
  }
  .team__section img {
    border-radius: 20px;
  }

  .counter {
    margin: 0;

    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 135px;
  }

  .counter__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .counter h1 {
    margin: 0;
    font-family: Cabin Variable;
    font-size: 50px;
    font-style: normal;
    font-weight: 700;
    line-height: 116%; /* 58px */
  }

  .counter p {
    margin: 0;
    padding-bottom: 150px;
    color: var(--color-text-muted);
    font-family: Cabin Variable;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: 116%; /* 20.88px */
  }

  /* Responsive */
  @media (max-width: 1280px) {
    .team__section {
      padding: var(--space-3xl) var(--space-l);
    }

    .faq {
      padding: var(--space-3xl) var(--space-l);
    }

    .faq__card {
      padding: var(--space-2xl) var(--space-xl);
    }
  }

  @media (max-width: 900px) {
    .counter {
      gap: var(--space-xl);
    }

    .team__content {
      grid-template-columns: 1fr;
    }

    .team__team {
      grid-column: 1;
      grid-row: 2;
    }
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--step-4);
    }

    .hero__subhead {
      font-size: var(--step-1);
    }

    .counter {
      flex-wrap: wrap;
      gap: var(--space-l);
      padding: 0 var(--space-l);
    }

    .counter p {
      padding-bottom: var(--space-m);
    }

    .team__section {
      padding: var(--space-2xl) var(--space-l);
    }

    .team__responsive {
      flex-direction: column;
      align-items: flex-start;
    }

    .faq__card {
      padding: var(--space-xl) var(--space-l);
    }

    .faq {
      margin-bottom: var(--space-3xl);
    }

    .faq__title {
      font-size: var(--step-2);
    }
  }
</style>
