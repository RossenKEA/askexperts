---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import WhatToExpect from "../components/WhatToExpect.astro";
import CoreValues from "../components/CoreValues.astro";
import ourvisionImage from "../assets/ourvision.png";
---

<Layout>
  <Header />

  <section class="hero">
    <div class="hero__heading">
      <p class="hero__label">ABOUT</p>
      <h1 class="hero__title">Igniting Innovation</h1>
    </div>

    <p class="hero__subhead">
      Our strength lies in the collaboration between our talented teams and
      esteemed clients. We cultivate a workplace that champions innovation,
      promotes peak performance, and guarantees client satisfaction.
    </p>
  </section>
  <WhatToExpect
    reverse={true}
    imageSrc={ourvisionImage.src}
    imageAlt="Image of employees"
    eyebrow="OUR VISION"
    heading="Turn your ideas into reality."
    body="Capitalize on low hanging fruit to identify a ballpark value added activity beta test. Override the digital divide with additional from DevOps."
    items={[
      "Bring to the table win-win survival strategies to ensure proactive domination. At the end of the day.",
      "Capitalize on low hanging fruit to identify a ballpark value added activity to beta test override the digital.",
    ]}
  />
  <div class="counter">
    <div class="counter__text">
      <h1>1128+</h1>
      <p>Successful Work</p>
    </div>
    <div class="counter__text">
      <h1>908+</h1>
      <p>Team member</p>
    </div>
    <div class="counter__text">
      <h1>258+</h1>
      <p>Happy Customers</p>
    </div>
    <div class="counter__text">
      <h1>564+</h1>
      <p>Creative Idea</p>
    </div>
  </div>
  <CoreValues />
  <Footer />
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding: var(--space-3xl) var(--space-l);
    margin-bottom: var(--space-3xl);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #f9fafb 66%);
  }

  .hero__label {
    text-align: center;
    color: var(--color-black);
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 147.5%;
    letter-spacing: 2.32px;
    text-transform: uppercase;
  }

  .hero__title {
    margin: 0;
    color: var(--color-black);
    font-family: "Cabin Variable";
    font-size: 60px;
    font-weight: 700;
    line-height: 116%;
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 7px;
    text-underline-offset: 6px;
  }

  .hero__subhead {
    max-width: 700px;
    text-align: center;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 22px;
    font-weight: 400;
    line-height: 147.5%;
  }

  .counter {
    margin: 0;

    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 135px;
  }

  .counter__text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .counter h1 {
    margin: 0;
    font-family: Cabin Variable;
    font-size: 50px;
    font-style: normal;
    font-weight: 700;
    line-height: 116%; /* 58px */
  }

  .counter p {
    margin: 0;
    padding-bottom: 150px;
    color: var(--color-text-muted);
    font-family: Cabin Variable;
    font-size: 18px;
    font-style: normal;
    font-weight: 500;
    line-height: 116%; /* 20.88px */
  }
</style>
