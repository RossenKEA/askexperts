---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import greenmark from "../assets/icon_greenmark.png";

const visionItems = [
  "Bring to the table win-win survival strategies to ensure proactive domination. At the end of the day.",
  "Capitalize on low hanging fruit to identify a ballpark value added activity to beta test override the digital.",
];
---

<Layout>
  <Header />

  <section class="hero">
    <div class="hero__heading">
      <p class="hero__label">ABOUT</p>
      <h1 class="hero__title">Igniting Innovation</h1>
    </div>

    <p class="hero__subhead">
      Our strength lies in the collaboration between our talented teams and
      esteemed clients. We cultivate a workplace that champions innovation,
      promotes peak performance, and guarantees client satisfaction.
    </p>
  </section>

  <section class="section">
    <header class="section__header">
      <p class="section__label">OUR VISION</p>
      <h2 class="section__title">Turn your ideas into reality.</h2>
      <p class="section__copy">
        Capitalize on low hanging fruit to identify a ballpark value added
        activity beta test. Override the digital divide with additional from
        DevOps.
      </p>
    </header>

    <ul class="checklist">
      {
        visionItems.map((text) => (
          <li class="checklist__item">
            <Image
              src={greenmark}
              alt="Green checkmark"
              class="checklist__icon"
            />
            <p class="checklist__text">{text}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <Footer />
</Layout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    padding: 100px 2.5rem;
    margin-bottom: 100px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0) 0%, #f9fafb 66%);
  }

  .hero__label,
  .section__label {
    text-align: center;
    color: action;
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 147.5%;
    letter-spacing: 2.32px;
    text-transform: uppercase;
  }

  .hero__title {
    margin: 0;
    color: action;
    font-family: "Cabin Variable";
    font-size: 60px;
    font-weight: 700;
    line-height: 116%;
    text-decoration: underline;
    text-decoration-color: action;
    text-decoration-thickness: 7px;
    text-underline-offset: 6px;
  }

  .hero__subhead {
    max-width: 700px;
    text-align: center;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 22px;
    font-weight: 400;
    line-height: 147.5%;
  }

  .section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    max-width: 980px;
    margin: 0 auto 100px;
    padding: 0 2.5rem;
  }

  .section__header {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 590px;
  }

  .section__title {
    margin: 0;
    color: action;
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
  }

  .section__copy {
    margin: 0;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 147.5%;
  }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 590px;
  }

  .checklist__item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
  }

  .checklist__icon {
    width: 20px;
    height: 20px;
  }

  .checklist__text {
    margin: 0;
    color: var(--color-text-muted);
    font-family: "Cabin Variable";
    font-size: 16px;
    font-weight: 400;
    line-height: 116%;
  }
</style>
