---
interface Props {
  text: string;
  paddingX?: string;
  bgColor?: string;
  textColor?: string;
}

const { text, paddingX = "16px", bgColor = "#000000", textColor = "#f9fafb" } = Astro.props;
---

<button class="btn" style={`--btn-padding-x:${paddingX}; --btn-bg:${bgColor}; --btn-text-color:${textColor};`}>
  <span class="btn-text">{text}</span>
</button>

<style>
  .btn {
    display: flex;
    padding: 4px var(--btn-padding-x);
    justify-content: center;
    align-items: center;
    gap: 10px;
    align-self: stretch;
    border-radius: 999px;

    background: var(--btn-bg);
    border: none;
    cursor: pointer;
  }

  .btn-text {
    color: var(--btn-text-color);
    font-size: 17.728px;
    font-style: normal;
    font-weight: 400;
    line-height: 160%;
  }
</style>
