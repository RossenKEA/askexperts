---
interface Props {
  text: string;
  paddingX?: string;
  paddingY?: string;
  bgColor?: string;
  textColor?: string;
  borderColor?: string;
  id?: string;
  popovertarget?: string;
}

const {
  text,
  paddingX = "16px",
  paddingY = "4px",
  bgColor = "#000000",
  textColor = "#f9fafb",
  borderColor = "transparent",
  id,
  popovertarget,
} = Astro.props;
---

<button
  class="btn"
  style={`--btn-padding-x:${paddingX}; --btn-padding-y:${paddingY}; --btn-bg:${bgColor}; --btn-text-color:${textColor}; --btn-border:${borderColor};`}
  id={id}
  popovertarget={popovertarget}
>
  <span class="btn-text">{text}</span>
</button>

<style>
  .btn {
    display: flex;
    padding: var(--btn-padding-y) var(--btn-padding-x);
    justify-content: center;
    align-items: center;
    gap: 10px;
    align-self: stretch;
    border-radius: 999px;

    background: var(--btn-bg);
    border: 1.5px solid var(--btn-border);
    cursor: pointer;
  }

  .btn-text {
    color: var(--btn-text-color);
    font-size: var(--step-0, 17px);
    font-style: normal;
    font-weight: 400;
    line-height: 160%;
  }
</style>
