---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import Login from "./Login.astro";
---

<header>
  <div id="header_inner">
    <Logo />
    <ul>
      <li><a href="/">Home</a></li>
      <li>Case Study</li>
      <li>Team</li>
      <li><a href="about">About</a></li>
    </ul>
    <div id="header_button">
      <Button
        id="login-btn"
        text="Login"
        paddingX="16px"
        bgColor="var(--color-white)"
        textColor="var(--color-black)"
        popovertarget="login-popover"
      />
    </div>
  </div>
</header>

<Login />

<style>
  header {
    background: var(--color-black);
    backdrop-filter: blur(10.5px);

    display: flex;
    width: 100%;
    padding: var(--space-l) 0;
    justify-content: center;
    align-items: flex-start;
  }

  #header_inner {
    display: grid;
    width: 1200px;
    max-width: 1200px;
    margin: 0 auto;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  header ul {
    display: inline-flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: nowrap;
    white-space: nowrap;
    grid-column: 2;

    list-style: none;
    margin: 0;
    padding: 0;

    color: var(--color-white);
  }

  header li {
    font-family: "Lato";
    color: var(--color-white);
    font-size: var(--step-0);
    font-style: normal;
    font-weight: 400;
    line-height: 160%;
  }

  header a {
    text-decoration: none;
    color: inherit;
  }

  #header_button {
    display: flex;
    width: fit-content;
    align-items: center;
    grid-column: 3;
    justify-self: end;
  }

  /* Anchor */
  #login-btn {
    anchor-name: --login-anchor;
  }
</style>
