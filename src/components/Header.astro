---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import Login from "./Login.astro";
---

<header>
  <div id="header_inner">
    <Logo />
    <ul id="nav_links">
      <li><a href="/">Home</a></li>
      <li><a href="/case-study">Case Study</a></li>
      <li><a href="/team">Team</a></li>
      <li><a href="/about">About</a></li>
    </ul>
    <div id="header_right">
      <div id="header_button">
        <Button
          id="login-btn"
          text="Login"
          paddingX="16px"
          bgColor="var(--color-white)"
          textColor="var(--color-black)"
          popovertarget="login-popover"
        />
      </div>
      <button id="burger" aria-label="Åbn menu" aria-expanded="false">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <nav id="mobile_menu">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/case-study">Case Study</a></li>
      <li><a href="/team">Team</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </nav>
</header>

<Login />

<script>
  const burger = document.getElementById("burger");
  const menu = document.getElementById("mobile_menu");

  burger?.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    menu?.classList.toggle("open", !open);
    burger.classList.toggle("active", !open);
  });
</script>

<style>
  header {
    background: var(--color-black);
    backdrop-filter: blur(10.5px);
    width: 100%;
  }

  /* Top bar */
  #header_inner {
    display: grid;
    max-width: 1200px;
    margin: 0 auto;
    padding: var(--space-l) var(--space-l);
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  /* Nav links */
  #nav_links {
    display: inline-flex;
    align-items: center;
    gap: var(--space-m);
    flex-wrap: nowrap;
    white-space: nowrap;
    grid-column: 2;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  header li {
    font-family: "Lato";
    color: var(--color-white);
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 160%;
  }

  header a {
    text-decoration: none;
    color: var(--color-white);
  }

  /* Right side */
  #header_right {
    grid-column: 3;
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-s);
  }

  /* Anchor */
  #login-btn {
    anchor-name: --login-anchor;
  }

  /* Burger */
  #burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  #burger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-white);
    border-radius: 2px;
    transition: transform 0.25s, opacity 0.25s;
  }

  #burger.active span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  #burger.active span:nth-child(2) {
    opacity: 0;
  }

  #burger.active span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu */
  #mobile_menu {
    display: none;
    background: var(--color-black);
    padding: var(--space-m) var(--space-l);
    border-top: 1px solid var(--color-border);
  }

  #mobile_menu.open {
    display: block;
  }

  #mobile_menu ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  #mobile_menu li {
    font-family: "Lato";
    font-size: var(--step-1);
    font-weight: 400;
    line-height: 160%;
    color: var(--color-white);
  }

  /* Responsive */
  @media (max-width: 600px) {
    #nav_links {
      display: none;
    }

    #burger {
      display: flex;
    }
  }

  @media (min-width: 601px) {
    #mobile_menu {
      display: none !important;
    }
  }
</style>
