---
import Button from "./Button.astro";
---

<section id="newsletter">
  <div id="newsletter_inner">
    <p class="newsletter_eyebrow">STAY UPDATED</p>
    <h2 class="newsletter_heading">Subscribe Our Newsletter</h2>
    <p class="newsletter_subtitle">
      Build stronger Customer Relationships with <span class="newsletter_brand">AskExperts</span>
    </p>
    <div id="newsletter_form">
      <input type="email" placeholder="your mail address" id="newsletter_email" />
      <Button
        text="Subscribe"
        paddingX="32px"
        bgColor="var(--color-yellow)"
        textColor="var(--color-black)"
      />
    </div>
  </div>
</section>

<style>
  #newsletter {
    background: var(--color-black);
    border-bottom: 1px solid var(--color-border);
    width: 100%;
    padding-top: var(--space-xl);
    padding-left: 360px;
    padding-right: 360px;
    padding-bottom: calc(var(--space-xl) + var(--footer-height));
    box-sizing: border-box;
  }

  #newsletter_inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
  }

  .newsletter_eyebrow {
    font-family: "Lato";
    font-size: var(--step--1);
    font-weight: 400;
    line-height: 160%;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-yellow);
    margin: 0;
  }

  .newsletter_heading {
    font-family: "Cabin Variable";
    font-size: var(--step-3);
    font-weight: 600;
    line-height: 120%;
    color: var(--color-white);
    margin: 0;
    text-align: center;
  }

  .newsletter_subtitle {
    font-family: "Lato";
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 160%;
    color: var(--color-white);
    margin: 0;
    text-align: center;
  }

  .newsletter_brand {
    color: var(--color-yellow);
    font-weight: 700;
  }

  #newsletter_form {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-top: var(--space-s);
  }

  #newsletter_email {
    width: 280px;
    padding: 10px 20px;
    border-radius: 999px;
    border: 1.5px solid var(--color-white);
    background: transparent;
    color: var(--color-white);
    font-family: "Lato";
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 160%;
    outline: none;
    box-sizing: border-box;
  }

  #newsletter_email::placeholder {
    color: hsl(from var(--color-white) h s l / 0.5);
  }

  @media (max-width: 1280px) {
    #newsletter {
      padding-left: 80px;
      padding-right: 80px;
    }
  }

  @media (max-width: 768px) {
    #newsletter {
      padding-left: var(--space-l);
      padding-right: var(--space-l);
    }

    #newsletter_form {
      flex-direction: column;
      width: 100%;
    }

    #newsletter_email {
      width: 100%;
    }
  }
</style>