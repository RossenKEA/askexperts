---
import icon5 from "../assets/Icon5.png";
import icon6 from "../assets/Icon6.png";
import icon7 from "../assets/Icon7.png";
import icon8 from "../assets/Icon8.png";

export interface Props {
  eyebrow?: string;
  heading?: string;
  body?: string;
  buttonText?: string;
  dark?: boolean;
}

const {
  eyebrow = "GROWING WITH OUR CLIENTS",
  heading = "Our core values & principles",
  body = "Capitalize on low hanging fruit to identify a ballpark value added activity beta test. Override the digital divide with additional from DevOps.",
  buttonText = "Get in touch",
  dark = false,
} = Astro.props;

const cards = [
  {
    icon: icon5.src,
    title: "Creative Ideas",
    body: "Explore innovative strategies tailored to your goals. Unlock unique solutions that inspire growth and creativity. Drive impactful change.",
  },
  {
    icon: icon6.src,
    title: "Best Features",
    body: "Deliver advanced tools designed for seamless integration. Optimize workflows with cutting-edge technology.",
  },
  {
    icon: icon7.src,
    title: "Experience",
    body: "Leverage years of proven expertise across diverse industries. Empower your business with our skilled professionals. Achieve sustainable success.",
  },
  {
    icon: icon8.src,
    title: "Easy Solutions",
    body: "Streamline your challenges with simple, effective solutions. Ensure hassle-free implementation for measurable results.",
  },
];
---

<section id="cv" style={`background:${dark ? "#030712" : "#F9FAFB"}`}>
  <div id="cv_inner" class="flow">
    <div id="cv_header">
      <div id="cv_text" class="flow">
        <p class="cv_eyebrow">{eyebrow}</p>
        <h2 class="cv_heading">{heading}</h2>
        <p class="cv_body">{body}</p>
      </div>
      <button class="cv_btn">{buttonText}</button>
    </div>

    <div id="cv_cards">
      {
        cards.map((card) => (
          <div class="cv_card flow">
            <div class="cv_icon">
              <img src={card.icon} alt="" aria-hidden="true" />
            </div>
            <h3 class="cv_card_title">{card.title}</h3>
            <p class="cv_card_body">{card.body}</p>
            <a href="#" class="cv_card_link">
              Read More →
            </a>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  #cv {
    grid-column: full;
    background: #030712;
    padding: var(--space-3xl) 0;
    display: grid;
    grid-template-columns: subgrid;
  }

  #cv_inner {
    grid-column: content;
    container-type: inline-size;
    display: flex;
    flex-direction: column;
    --flow-space: var(--space-xl);
  }
  #cv_inner > * + * {
    margin-top: var(--flow-space);
  }

  /* Header */
  #cv_header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--space-l);
  }

  #cv_text {
    display: flex;
    flex-direction: column;
    max-width: 560px;
    --flow-space: var(--space-xs);
  }
  #cv_text > * + * {
    margin-top: var(--flow-space);
  }

  .cv_eyebrow {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 148%;
    letter-spacing: 0.145em;
    text-transform: uppercase;
    color: var(--color-black);
    margin: 0;
  }

  #cv[style*="030712"] .cv_eyebrow {
    color: var(--color-muted);
  }

  .cv_heading {
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
    margin: 0;
  }

  #cv[style*="030712"] .cv_heading {
    color: var(--color-white);
  }

  .cv_body {
    font-family: "Lato";
    font-size: 18px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-text-muted);
    margin: 0;
  }

  #cv[style*="030712"] .cv_body {
    color: var(--color-muted);
  }

  /* Button */
  .cv_btn {
    font-family: "Lato";
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 160%;
    padding: 10px 28px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    flex-shrink: 0;
    background: var(--color-black);
    color: var(--color-white);
  }

  #cv[style*="030712"] .cv_btn {
    background: var(--color-white);
    color: var(--color-black);
  }

  /* Cards grid */
  #cv_cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-m);
    align-items: start;
  }

  /* Base card */
  .cv_card {
    background: var(--color-white);
    border-radius: 20px;
    border: 1px solid var(--color-border-light);
    padding: 36px 23px;
    display: flex;
    flex-direction: column;
  }

  /* Alternating sizes */
  .cv_card:nth-child(odd) {
    --flow-space: var(--space-2xs);
    height: 392px;
  }
  .cv_card:nth-child(even) {
    --flow-space: var(--space-xs);
    height: 363px;
  }
  .cv_card > * + * {
    margin-top: var(--flow-space);
  }

  /* Icon */
  .cv_icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #030712;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .cv_icon img {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .cv_card_title {
    font-family: "Cabin Variable";
    font-size: 20px;
    font-weight: 700;
    line-height: 130%;
    color: #030712;
    margin: 0;
  }

  .cv_card_body {
    font-family: "Lato";
    font-size: 18px;
    font-weight: 400;
    line-height: 160%;
    color: #595566;
    margin: 0;
    flex: 1;
  }

  .cv_card_link {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 160%;
    color: #030712;
    text-decoration: none;
    align-self: flex-start;
  }

  .cv_card_link:hover {
    text-decoration: underline;
  }

  @container (max-width: 900px) {
    #cv_cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @container (max-width: 768px) {
    #cv_header {
      flex-direction: column;
      align-items: flex-start;
    }

    #cv_cards {
      grid-template-columns: 1fr;
    }
  }
</style>
