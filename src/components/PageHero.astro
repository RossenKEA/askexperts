---
export interface Props {
  label: string;
  title: string;
  subhead: string;
}

const { label, title, subhead } = Astro.props;
---

<section class="hero flow">
  <div class="hero__heading flow">
    <p class="hero__label">{label}</p>
    <h1 class="hero__title">{title}</h1>
  </div>
  <p class="hero__subhead">{subhead}</p>
</section>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    --flow-space: var(--space-xl);
    padding: var(--space-3xl) var(--space-l);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0) 0%,
      var(--color-white) 66%
    );
  }
  .hero > * + * {
    margin-top: var(--flow-space);
  }

  .hero__heading {
    display: flex;
    flex-direction: column;
    align-items: center;
    --flow-space: var(--space-xs);
  }
  .hero__heading > * + * {
    margin-top: var(--flow-space);
  }

  .hero__label {
    margin: 0;
    text-align: center;
    color: var(--color-black);
    font-family: Lato;
    font-size: 16px;
    font-weight: 400;
    line-height: 147.5%;
    letter-spacing: 2.32px;
    text-transform: uppercase;
  }

  .hero__title {
    margin: 0;
    text-align: center;
    color: var(--color-black);
    font-family: "Cabin Variable";
    font-size: 60px;
    font-weight: 700;
    line-height: 116%;
    text-decoration: underline;
    text-decoration-color: var(--color-yellow);
    text-decoration-thickness: 7px;
    text-underline-offset: 6px;
  }

  .hero__subhead {
    max-width: 700px;
    margin: 0;
    text-align: center;
    color: var(--color-text-muted);
    font-family: Lato;
    font-size: 22px;
    font-weight: 400;
    line-height: 147.5%;
  }

  @media (max-width: 768px) {
    .hero__title {
      font-size: var(--step-4);
    }

    .hero__subhead {
      font-size: var(--step-1);
    }
  }
</style>
