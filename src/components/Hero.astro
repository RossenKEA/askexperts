---
import Button from "./Button.astro";
---

<section id="hero">
  <div id="hero_inner">
    <div id="hero_content">
      <h1 class="hero_heading">
        Empowering Your<br />Business Growth
      </h1>
      <p class="hero_subtitle">
        Discover tailored strategies and expert insights to take your
        business to the next level. Let us help you navigate challenges
        and achieve sustainable success.
      </p>
      <div id="hero_buttons">
        <Button
          text="Book a Meeting"
          paddingX="24px"
          bgColor="var(--color-yellow)"
          textColor="var(--color-black)"
        />
        <Button
          text="Learn More →"
          paddingX="24px"
          bgColor="transparent"
          textColor="var(--color-white)"
          borderColor="var(--color-white)"
        />
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    width: 100%;
    min-height: 560px;
    background-image: url("/banner.png");
    background-size: cover;
    background-position: right center;
    background-repeat: no-repeat;
    position: relative;
  }

  #hero_inner {
    max-width: 1200px;
    margin: 0 auto;
    min-height: 560px;
    display: flex;
    align-items: flex-start;
    padding: 120px 0 var(--space-2xl);
  }

  #hero_content {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
    max-width: 520px;
  }

  .hero_heading {
    font-family: "Cabin Variable";
    font-size: var(--step-4);
    font-weight: 700;
    line-height: 115%;
    color: var(--color-white);
    margin: 0;
  }

  .hero_heading::after {
    content: "";
    display: block;
    width: 60px;
    height: 2px;
    background: var(--color-yellow);
    margin-top: var(--space-xs);
  }

  .hero_subtitle {
    font-family: "Lato";
    font-size: var(--step-0);
    font-weight: 400;
    line-height: 160%;
    color: var(--color-muted);
    margin: 0;
  }

  #hero_buttons {
    display: flex;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    #hero {
      background-position: center center;
    }

    #hero_inner {
      padding: var(--space-xl) var(--space-l);
    }

    #hero_content {
      max-width: 100%;
    }
  }
</style>