---
import Button from "./Button.astro";
---

<section id="hero">
  <div id="hero_inner">
    <div id="hero_content">
      <h1 class="hero_heading">
        Empowering Your<br />Business Growth
      </h1>
      <p class="hero_subtitle">
        Discover tailored strategies and expert insights to take your business
        to the next level. Let us help you navigate challenges and achieve
        sustainable success.
      </p>
      <div id="hero_buttons">
        <Button
          text="Book a Meeting"
          paddingX="24px"
          paddingY="12px"
          bgColor="var(--color-yellow)"
          textColor="var(--color-black)"
        />
        <Button
          text="Learn More →"
          paddingX="24px"
          paddingY="12px"
          bgColor="transparent"
          textColor="var(--color-white)"
          borderColor="var(--color-white)"
        />
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    grid-column: full;
    min-height: 520px;
    background-color: var(--color-black);
    display: grid;
    grid-template-columns: subgrid;
    background-image:
      url("/banner.png"),
      repeating-linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      repeating-linear-gradient(
        90deg,
        rgba(255, 255, 255, 0.04) 1px,
        transparent 1px
      );
    background-size:
      auto 100%,
      44px 44px,
      44px 44px;
    background-position:
      right -180px top 0px,
      0 0,
      0 0;
    background-repeat: no-repeat, repeat, repeat;
    position: relative;
  }

  #hero_inner {
    grid-column: content;
    min-height: 520px;
    display: flex;
    align-items: flex-start;
    padding: var(--space-xl) 0 var(--space-2xl);
  }

  #hero_content {
    display: flex;
    flex-direction: column;
    max-width: 520px;
    --flow-space: var(--space-m);
  }
  #hero_content > * + * {
    margin-top: var(--flow-space);
  }

  .hero_heading {
    font-family: "Cabin Variable";
    font-size: 50px;
    font-weight: 700;
    line-height: 115%;
    color: var(--color-white);
    margin: 0;
  }

  .hero_heading::after {
    content: "";
    display: block;
    width: 60px;
    height: 2px;
    background: var(--color-yellow);
    margin-top: var(--space-xs);
  }

  .hero_subtitle {
    font-family: "Lato";
    font-size: 18px;
    font-weight: 400;
    line-height: 160%;
    color: var(--color-muted);
    margin: 0;
  }

  #hero_buttons {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    flex-wrap: wrap;
  }

  #hero_buttons :global(.btn) {
    align-self: center;
  }

  @media (max-width: 768px) {
    #hero {
      background-position: center center;
    }

    #hero_content {
      max-width: 100%;
    }
  }
</style>
