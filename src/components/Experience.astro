---

<section id="experience">
  <div id="exp_inner">

    <div id="exp_text">
      <p class="exp_eyebrow">EXPERIENCE</p>
      <h2 class="exp_heading">More than 25 years<br />of experience</h2>
      <p class="exp_body">3000+ our clients are insured around the World</p>
    </div>

    <div id="exp_stats">

      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="rgba(0,0,0,0.15)" stroke-width="4"/>
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="white" stroke-width="4"
              stroke-dasharray="267 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"/>
            <circle cx="60" cy="10" r="5" fill="var(--color-black)"/>
          </svg>
          <span class="exp_pct">85%</span>
        </div>
        <p class="exp_label">Consistency</p>
      </div>

      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="rgba(0,0,0,0.15)" stroke-width="4"/>
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="white" stroke-width="4"
              stroke-dasharray="298 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"/>
            <circle cx="60" cy="10" r="5" fill="var(--color-black)"/>
          </svg>
          <span class="exp_pct">95%</span>
        </div>
        <p class="exp_label">Improvement</p>
      </div>

      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="rgba(0,0,0,0.15)" stroke-width="4"/>
            <circle cx="60" cy="60" r="50" fill="none"
              stroke="white" stroke-width="4"
              stroke-dasharray="283 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"/>
            <circle cx="60" cy="10" r="5" fill="var(--color-black)"/>
          </svg>
          <span class="exp_pct">90%</span>
        </div>
        <p class="exp_label">Branching</p>
      </div>

    </div>
  </div>
</section>

<style>
  #experience {
    background: var(--color-yellow);
    width: 100%;
    padding: var(--space-3xl) 0;
  }

  #exp_inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-2xl);
  }

  /* Tekst */
  #exp_text {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
    max-width: 460px;
  }

  .exp_eyebrow {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 148%;
    letter-spacing: 0.145em;
    text-transform: uppercase;
    color: var(--color-black);
    margin: 0;
  }

  .exp_heading {
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
    margin: 0;
  }

  .exp_body {
    font-family: "Lato";
    font-size: 18px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-black);
    margin: 0;
  }

  /* Stats */
  #exp_stats {
    display: flex;
    justify-content: space-between;
    gap: var(--space-l);
    margin-top: var(--space-xl);
  }

  .exp_stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  /* Ring */
  .exp_ring_wrap {
    position: relative;
    width: 130px;
    height: 130px;
  }

  .exp_ring {
    width: 100%;
    height: 100%;
  }

  .exp_pct {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Cabin Variable";
    font-size: 24px;
    font-weight: 700;
    color: var(--color-black);
  }

  .exp_label {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-black);
    margin: 0;
  }

  @media (max-width: 1280px) {
    #exp_inner {
      padding: 0 var(--space-l);
    }
  }

  @media (max-width: 768px) {
    #exp_inner {
      grid-template-columns: 1fr;
    }

    #exp_stats {
      justify-content: center;
    }
  }
</style>
