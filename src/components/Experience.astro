<section id="experience">
  <div id="exp_inner">
    <div id="exp_text">
      <p class="exp_eyebrow">EXPERIENCE</p>
      <h2 class="exp_heading">More than 25 years<br />of experience</h2>
      <p class="exp_body">3000+ our clients are insured around the World</p>
    </div>

    <div id="exp_stats">
      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="rgba(0,0,0,0.15)"
              stroke-width="4"></circle>
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="white"
              stroke-width="4"
              stroke-dasharray="267 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"></circle>
            <circle cx="20" cy="31" r="5" fill="var(--color-black)"></circle>
          </svg>
          <span class="exp_pct">85%</span>
        </div>
        <p class="exp_label">Consistency</p>
      </div>

      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="rgba(0,0,0,0.15)"
              stroke-width="4"></circle>
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="white"
              stroke-width="4"
              stroke-dasharray="298 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"></circle>
            <circle cx="44" cy="13" r="5" fill="var(--color-black)"></circle>
          </svg>
          <span class="exp_pct">95%</span>
        </div>
        <p class="exp_label">Improvement</p>
      </div>

      <div class="exp_stat">
        <div class="exp_ring_wrap">
          <svg viewBox="0 0 120 120" class="exp_ring" aria-hidden="true">
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="rgba(0,0,0,0.15)"
              stroke-width="4"></circle>
            <circle
              cx="60"
              cy="60"
              r="50"
              fill="none"
              stroke="white"
              stroke-width="4"
              stroke-dasharray="283 314"
              stroke-linecap="round"
              transform="rotate(-90 60 60)"></circle>
            <circle cx="31" cy="19" r="5" fill="var(--color-black)"></circle>
          </svg>
          <span class="exp_pct">90%</span>
        </div>
        <p class="exp_label">Branching</p>
      </div>
    </div>
  </div>
</section>

<style>
  #experience {
    grid-column: full;
    background: var(--color-yellow);
    padding: var(--space-3xl) 0;
    display: grid;
    grid-template-columns: subgrid;
  }

  #exp_inner {
    grid-column: content;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-2xl);
  }

  /* Tekst */
  #exp_text {
    display: flex;
    flex-direction: column;
    max-width: 460px;
    --flow-space: var(--space-s);
  }
  #exp_text > * + * {
    margin-top: var(--flow-space);
  }

  .exp_eyebrow {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 148%;
    letter-spacing: 0.145em;
    text-transform: uppercase;
    color: var(--color-black);
    margin: 0;
  }

  .exp_heading {
    font-family: "Cabin Variable";
    font-size: 45px;
    font-weight: 700;
    line-height: 116%;
    color: var(--color-black);
    margin: 0;
  }

  .exp_body {
    font-family: "Lato";
    font-size: 18px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-black);
    margin: 0;
  }

  /* Stats */
  #exp_stats {
    display: flex;
    justify-content: space-between;
    gap: var(--space-l);
  }

  .exp_stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    --flow-space: var(--space-xs);
  }
  .exp_stat > * + * {
    margin-top: var(--flow-space);
  }

  /* Ring */
  .exp_ring_wrap {
    position: relative;
    width: 130px;
    height: 130px;
  }

  .exp_ring {
    width: 100%;
    height: 100%;
  }

  .exp_pct {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Cabin Variable";
    font-size: 24px;
    font-weight: 700;
    color: var(--color-black);
  }

  .exp_label {
    font-family: "Lato";
    font-size: 16px;
    font-weight: 400;
    line-height: 148%;
    color: var(--color-black);
    margin: 0;
  }

  @media (max-width: 768px) {
    #exp_inner {
      grid-template-columns: 1fr;
    }

    #exp_text {
      text-align: center;
      max-width: 100%;
    }

    #exp_stats {
      justify-content: center;
      margin-top: 0;
    }
  }
</style>
